# =============================================================================
# CMI Payment Gateway — Sandbox Configuration
# =============================================================================
# CMI (Centre Monétique Interbancaire) — Morocco's central payment gateway
# Sandbox URL: https://test.cmi.co.ma
# Production URL: https://pay.cmi.co.ma
# =============================================================================
# IMPORTANT: Never commit this file with real values.
# Copy to .env and fill in your sandbox credentials from CMI dashboard.
# =============================================================================

# Sandbox Mode — set to 'true' for testing
CMI_SANDBOX=true

# CMI Store Credentials (from CMI merchant dashboard)
CMI_STORE_ID=elmokef_sandbox
CMI_STORE_KEY=TEST_STORE_KEY_CHANGE_ME

# Merchant Info
CMI_MERCHANT_ID=ELMOKEF_MERCHANT_001
CMI_MERCHANT_EMAIL=merchant@elmokef.ma

# CMI Endpoints
CMI_BASE_URL=https://test.cmi.co.ma
CMI_PAY_URL=https://test.cmi.co.ma/fim/est3Dgate
CMI_OK_URL=https://api.elmokef.ma/api/v1/payments/success
CMI_FAIL_URL=https://api.elmokef.ma/api/v1/payments/failure
CMI_CALLBACK_URL=https://api.elmokef.ma/api/v1/payments/webhook

# Currency (504 = Moroccan Dirham MAD)
CMI_CURRENCY=504

# Language: ar, fr, en
CMI_LANG=ar

# =============================================================================
# CMI Sandbox Test Cards (from CMI documentation)
# =============================================================================
# Card: VISA Success       → 4155 6500 0000 0000 | Exp: 12/26 | CVV: 123
# Card: VISA Failure       → 4155 6500 0000 0001 | Exp: 12/26 | CVV: 123
# Card: MasterCard Success → 5450 0000 0000 0000 | Exp: 12/26 | CVV: 123
# Card: 3D Secure          → 4000 0000 0000 0002 | Exp: 12/26 | CVV: 123
# =============================================================================
